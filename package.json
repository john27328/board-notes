{
  "name": "board-notes",
  "version": "0.1.0",
  "description": "Interactive Kanban boards rendered from a code block, backed entirely by note frontmatter.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "deploy": "npm run check && node scripts/deploy.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  }
}
